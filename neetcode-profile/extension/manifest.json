{
  "manifest_version": 3,
  "name": "NeetCode Profile Share",
  "version": "1.0.0",
  "description": "Auto-generate a shareable public NeetCode profile for your resume.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://neetcode.io/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://neetcode.io/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "NeetCode Profile Share",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}